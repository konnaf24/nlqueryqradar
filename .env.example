# Base URL of the QRadar console (required)
QRADAR_URL=https://qradar.corp.com

# Authorized service token used as the SEC header value (required)
QRADAR_API_TOKEN=your-authorized-service-token

# Set to 1 to enforce strict TLS. Leave unset (or 0) to allow self-signed
# certificates, which are common in on-premises QRadar deployments.
NODE_TLS_REJECT_UNAUTHORIZED=0

# HTTP request timeout in milliseconds (optional, default 30000)
QRADAR_TIMEOUT_MS=30000

# AQL search poll interval in milliseconds (optional, default 1000)
QRADAR_POLL_INTERVAL_MS=1000

# Max poll attempts before an AQL search times out (optional, default 60)
QRADAR_MAX_POLL_ATTEMPTS=60
